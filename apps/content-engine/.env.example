# Content engine's own database
ENGINE_DATABASE_URL=postgresql+asyncpg://engine:engine_pass@localhost:5433/content_engine

# I♥Berlin API connection
ILOVEBERLIN_API_URL=http://localhost:3001/api
ILOVEBERLIN_ADMIN_EMAIL=admin@iloveberlin.biz
ILOVEBERLIN_ADMIN_PASSWORD=your-admin-password-here

# AI (Kimi K2.5 via OpenAI-compatible API)
KIMI_API_KEY=your-kimi-api-key-here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5

# YouTube Data API v3 (free tier)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Admin panel password (generate a bcrypt hash)
ADMIN_PASSWORD_HASH=$2b$12$your-bcrypt-hash-here

# Logging
LOG_LEVEL=INFO
